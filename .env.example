# ===== MONGODB CONFIGURATION =====
# 
# For LOCAL development:
# MONGODB_URI=mongodb://localhost:27017
#
# For MongoDB Atlas Cloud (RECOMMENDED for Vercel):
# MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/
#
# ⚠️  IMPORTANT: Always use MongoDB Atlas for Vercel deployment
#    Local MongoDB will not work on Vercel serverless functions

MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/
MONGODB_DB_NAME=spoms

# ===== FLASK CONFIGURATION =====
FLASK_ENV=development
SECRET_KEY=your-secret-key-change-in-production-2026

# ===== VERCEL DEPLOYMENT SETUP =====
# When deploying to Vercel:
# 1. Create MongoDB Atlas cluster (free tier available)
# 2. Create MongoDB database user with strong password
# 3. Whitelist Vercel IPs or use "0.0.0.0/0" (with caution)
# 4. Copy connection string and update MONGODB_URI above
# 5. Set SECRET_KEY to a secure random string
# 6. In Vercel Dashboard → Settings → Environment Variables:
#    - Add MONGODB_URI
#    - Add SECRET_KEY
#    - Add MONGODB_DB_NAME
#    - Add FLASK_ENV=production
# 7. Deploy and verify MongoDB connection in logs

# ===== OPTIONAL SETTINGS =====
# SESSION_TIMEOUT=3600
# SESSION_COOKIE_SECURE=True  # Enable for HTTPS in production
# SESSION_COOKIE_HTTPONLY=True
# SESSION_COOKIE_SAMESITE=Lax

